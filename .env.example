# ══════════════════════════════════════════════════════════════
#  SourceMind — Environment Variables Template
#  Copy this file to backend/.env and fill in your values
#  cp .env.example backend/.env
# ══════════════════════════════════════════════════════════════

# Application Environment (development | production)
APP_ENV=development
LOG_LEVEL=INFO

# CORS Origin for Frontend
FRONTEND_ORIGIN=http://localhost:5173

# ── LLM Inference (Groq) ──────────────────────────────────────
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Local Embeddings (Ollama) ──────────────────────────────────
# Default for local dev. Use http://ollama:11434 when running via Docker.
OLLAMA_BASE_URL=http://localhost:11434

# ── Cloud Vector Store (Optional — for Production) ─────────────
QDRANT_URL=
QDRANT_API_KEY=
