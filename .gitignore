# ══════════════════════════════════════════════════════════════
#  SourceMind — .gitignore
#  Protects secrets, build artifacts, and generated files
#  Last Updated: May 2026
# ══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
#  🔒 SECRETS & ENVIRONMENT FILES
#  CRITICAL: Never commit API keys, tokens, or credentials
# ──────────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.*.local
backend/.env
frontend/.env

# Keep templates for onboarding
!.env.example
!backend/.env.example
!frontend/.env.example


# ──────────────────────────────────────────────────────────────
#  🐍 PYTHON — Backend
# ──────────────────────────────────────────────────────────────

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
*.whl
uv.lock

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# MyPy / type checker
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/


# ──────────────────────────────────────────────────────────────
#  ⚛️  NODE.JS / REACT — Frontend
# ──────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Build output
frontend/dist/
frontend/build/

# Vite
*.local

# TypeScript cache
*.tsbuildinfo

# ESLint cache
.eslintcache

# Vitest
coverage/


# ──────────────────────────────────────────────────────────────
#  🗄️  DATA & STORAGE (Runtime-generated)
# ──────────────────────────────────────────────────────────────

# ChromaDB persistent storage (local dev data)
backend/chroma_db/*
!backend/chroma_db/.gitkeep

# SQLite databases (if any)
*.sqlite
*.sqlite3
*.db

# Log files
backend/logs/*
!backend/logs/.gitkeep
*.log

# Uploaded files (user PDFs during runtime)
backend/uploads/
backend/tmp/


# ──────────────────────────────────────────────────────────────
#  🐳 DOCKER (Runtime volumes & overrides)
# ──────────────────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.local.yml


# ──────────────────────────────────────────────────────────────
#  💻 IDE & EDITOR FILES
# ──────────────────────────────────────────────────────────────

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains (PyCharm, WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# Cursor AI
.cursorignore
.cursorrules


# ──────────────────────────────────────────────────────────────
#  🖥️  OS-GENERATED FILES
# ──────────────────────────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*


# ──────────────────────────────────────────────────────────────
#  🔧 SCAFFOLD & TEMPORARY FILES
# ──────────────────────────────────────────────────────────────
scaffold.sh


# ──────────────────────────────────────────────────────────────
#  🤖 AI TOOL CACHES
# ──────────────────────────────────────────────────────────────
.gemini/
.copilot/
.aider*
.continue/
